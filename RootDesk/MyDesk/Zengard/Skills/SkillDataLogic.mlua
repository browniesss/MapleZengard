		addSkill({ skillId = "warrior_weapon_booster", displayName = "웨폰 부스터", job = "warrior", kind = "PASSIVE",
			jobTier = 2, advRoute = "",
			passiveType = "ATK_SPEED", passiveValuePerLv = { 0.12, 0.18, 0.25 },
