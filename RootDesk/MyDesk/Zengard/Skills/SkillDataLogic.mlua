			damagePerLv = { 4, 6, 8 }, element = "LIGHTNING", critChanceBonus = 0.10,
			desc = "번개의 창으로 멀리 있는 적 하나를 세 번 꿰뚫습니다.",
			iconRuid = "thumbnail://df732e3d54da4d9bb5b97ca0f938b56f" })
		addSkill({ skillId = "mage_holy_symbol", displayName = "홀리 심볼", job = "mage", kind = "PASSIVE",
			jobTier = 3, advRoute = "bishop", element = "HOLY",
			passiveType = "EXP_GAIN", passiveValuePerLv = { 0.15, 0.25, 0.35 },
			desc = "성스러운 상징으로 획득 경험치를 크게 증가시킵니다.",
			iconRuid = "thumbnail://dcb4c7f7039147e0ac88ac981e9fafc9" })
		addSkill({ skillId = "mage_shining_ray", displayName = "샤이닝 레이", job = "mage", kind = "ACTIVE",
			jobTier = 3, advRoute = "bishop", shape = "LINE", range = 6, hits = 2,
			damagePerLv = { 4, 6, 8 }, element = "HOLY", linePierce = true, directional = true,
			desc = "성스러운 빛줄기로 직선상의 적을 두 번 관통합니다.",
			iconRuid = "thumbnail://786320718c6a4d06bdc3eec55fd0b7d9" })

		addSkill({ skillId = "mage_poison_mist", displayName = "포이즌 미스트", job = "mage", kind = "ACTIVE",
			jobTier = 3, advRoute = "firepoison", shape = "ADJACENT8", range = 1, hits = 2,
			damagePerLv = { 7, 10, 14 }, element = "POISON",
			desc = "독안개로 주위 8방의 적을 2회 잠식",
			iconRuid = "78031d46ae3847fbabd0de6ae43011dc" })

		self.skillTable = skills

		-- Fixed fusion recipes (MASTER_PLAN §7.4 / spec §4.2). Data-driven: add rows only.
		local recipes = {}
		local order = {}

		local function addRecipe(rec)
			recipes[rec.recipeId] = rec
			table.insert(order, rec.recipeId)
		end

		addRecipe({ recipeId = "recipe_archer_double_ice", job = "archer",
			materialA = "archer_double_shot", materialB = "archer_ice_shot", result = "archer_double_ice_shot" })
		addRecipe({ recipeId = "recipe_warrior_power_blast", job = "warrior",
			materialA = "warrior_power_strike", materialB = "warrior_slash_blast", result = "warrior_power_blast" })
		addRecipe({ recipeId = "recipe_mage_energy_claw", job = "mage",
			materialA = "mage_energy_bolt", materialB = "mage_magic_claw", result = "mage_energy_claw" })
		addRecipe({ recipeId = "recipe_thief_triple_seven", job = "thief",
			materialA = "thief_lucky_seven", materialB = "thief_double_stab", result = "thief_triple_seven" })

		self.recipeTable = recipes
		self.recipeOrder = order

		-- Initial 2-pick pools: attack skills only (R2) — ice_shot is a material, excluded here.
		self.initialSkillTable = {
			warrior = { "warrior_power_strike", "warrior_slash_blast" },
			archer = { "archer_arrow_blow", "archer_double_shot" },
			mage = { "mage_energy_bolt", "mage_magic_claw" },
			thief = { "thief_double_stab", "thief_lucky_seven" },
		}
	end

	method table GetSkillData(string skillId)
		-- Returns the full skill record (§3.1 schema) or nil when unknown.
		self:EnsureLoaded()
		return self.skillTable[skillId]
	end

	method table GetJobInitialSkillIds(string jobId)
		-- Returns the two initial attack skill ids for the job (R1/R2).
		self:EnsureLoaded()
		local ids = self.initialSkillTable[jobId]
		if ids == nil then
			log_warning("[SkillDataLogic] GetJobInitialSkillIds: unknown jobId " .. tostring(jobId))
			return {}
		end
		local copied = {}
		for i = 1, self.INITIAL_CHOICE_COUNT do
			copied[i] = ids[i]
		end
		return copied
	end

	method table GetJobSkillPool(string jobId)
		-- Acquirable pool for the job (active + material + passive), excluding fusion results.
		self:EnsureLoaded()
		local pool = {}
		for _, rec in pairs(self.skillTable) do
			if rec.job == jobId and rec.kind ~= "FUSION" then
				table.insert(pool, rec)
			end
		end
		return pool
	end

	method table GetRecipe(string recipeId)
		-- Returns one fusion recipe row or nil.
		self:EnsureLoaded()
		return self.recipeTable[recipeId]
	end

	method table GetRecipesByJob(string jobId)
		-- Returns the job's fusion recipe rows in declaration order (deterministic iteration).
		self:EnsureLoaded()
		local found = {}
		for _, recipeId in ipairs(self.recipeOrder) do
			local rec = self.recipeTable[recipeId]
			if rec.job == jobId then
				table.insert(found, rec)
			end
		end
		return found
	end

end
