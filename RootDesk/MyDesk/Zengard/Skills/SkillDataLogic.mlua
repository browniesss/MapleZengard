		addSkill({ skillId = "archer_ice_shot", displayName = "아이스샷", job = "archer", kind = "ACTIVE",
			shape = "LINE", range = 7, hits = 1, damagePerLv = { 3, 4, 6 }, element = "ICE", directional = true,
			desc = "얼음 화살을 직선으로 발사 (합성 재료)",
			iconRuid = "754505598cd0402ebd2ca77c19efd325" })
		addSkill({ skillId = "mage_energy_bolt", displayName = "에너지 볼트", job = "mage", kind = "ACTIVE",
			shape = "ADJACENT8", range = 1, hits = 1, damagePerLv = { 2, 3, 4 },
			desc = "주위 8방향의 모든 적에게 마력 폭발",
			iconRuid = "1f06d7f1824b4d0d96aebb91e3aa1c83" })
		addSkill({ skillId = "mage_magic_claw", displayName = "매직 클로", job = "mage", kind = "ACTIVE",
			shape = "RANGED_TARGET", range = 3, hits = 2, damagePerLv = { 1, 2, 3 },
			desc = "원거리 대상을 마법으로 2회 연타",
			iconRuid = "148f8efbefd24019a95861bf6efd87dc" })
		addSkill({ skillId = "thief_double_stab", displayName = "더블 스텝", job = "thief", kind = "ACTIVE",
			shape = "RANGED_TARGET", range = 2, hits = 2, damagePerLv = { 2, 3, 4 },
