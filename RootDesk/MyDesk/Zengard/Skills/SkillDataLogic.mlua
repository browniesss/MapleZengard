		addSkill({ skillId = "thief_lucky_seven", displayName = "럭키 세븐", job = "thief", kind = "ACTIVE",
			shape = "RANGED_TARGET", range = 5, hits = 2, damagePerLv = { 2, 3, 4 }, critChanceBonus = 0.10,
			desc = "표창 2개를 던지며 치명타 확률 +10%p",
			iconRuid = "a49c086a08b14c19bb7b9ae483dff2cc" })

		-- Tier-2 skills. Representative 2nd-job branches per base job, translated for the live cards.
		addSkill({ skillId = "warrior_rage", displayName = "분노", job = "warrior", kind = "ACTIVE",
			jobTier = 2, advRoute = "fighter", shape = "ADJACENT4", range = 1, hits = 2,
			damagePerLv = { 3, 4, 6 },
