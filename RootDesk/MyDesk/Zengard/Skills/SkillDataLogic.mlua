@Logic
script SkillDataLogic extends Logic

	-- Balance constants (MASTER_PLAN §7.4) — single source, other systems must read these.
	property integer SKILL_MAX_LEVEL = 3
	property integer INITIAL_CHOICE_COUNT = 2
	property number FUSION_CHOICE_CHANCE = 0.30
	property number BASE_CRIT_CHANCE = 0.10
	property number CRIT_MULTIPLIER = 2.0
	property integer MAX_OWNED_SKILLS = 8

	property any skillTable = nil
	property any recipeTable = nil
	property any recipeOrder = nil
	property any initialSkillTable = nil

	method void OnInitialize()
		-- Build the catalog on both sides so client UI can also query names/icons.
		self:EnsureLoaded()
	end

	method void OnBeginPlay()
		-- OnInitialize ordering across @Logic instances is not guaranteed, so re-assert here;
		-- the skillTable guard makes EnsureLoaded idempotent.
		self:EnsureLoaded()
		log("[SkillDataLogic] OnBeginPlay")
	end

	method void EnsureLoaded()
		-- Lazy guard: other Logics' OnBeginPlay may run before this one's OnInitialize.
		if self.skillTable ~= nil then
			return
		end

		local skills = {}

		local function addSkill(rec)
			-- Defaults keep every record schema-complete so consumers can read any field.
			if rec.jobTier == nil then rec.jobTier = 1 end
			if rec.advRoute == nil then rec.advRoute = "" end
			if rec.element == nil then rec.element = "NONE" end
			if rec.directional == nil then rec.directional = false end
			if rec.linePierce == nil then rec.linePierce = false end
			if rec.passiveType == nil then rec.passiveType = "" end
			if rec.passiveValuePerLv == nil then rec.passiveValuePerLv = {} end
			if rec.extraActionDamageMul == nil then rec.extraActionDamageMul = 0.0 end
			if rec.critChanceBonus == nil then rec.critChanceBonus = 0.0 end
			if rec.hits == nil then rec.hits = 0 end
			if rec.range == nil then rec.range = 0 end
			if rec.damagePerLv == nil then rec.damagePerLv = {} end
			if rec.desc == nil then rec.desc = "" end
			-- RUID 필요: icon/effect/sound RUIDs unresolved at authoring time (see worker report).
			if rec.iconRuid == nil then rec.iconRuid = "" end
			if rec.effectRuid == nil then rec.effectRuid = "" end
			if rec.soundRuid == nil then rec.soundRuid = "" end
			skills[rec.skillId] = rec
		end

		-- Tier-1 active skills (MASTER_PLAN §7.4, names from the design doc p.12).
		addSkill({ skillId = "warrior_power_strike", displayName = "파워 스트라이크", job = "warrior", kind = "ACTIVE",
			shape = "ADJACENT4_SINGLE", range = 1, hits = 1, damagePerLv = { 4, 6, 9 },
			desc = "인접한 적 하나에게 강력한 단일 타격",
			iconRuid = "e4acdf27d68549db8858d6082169c70c" })
		addSkill({ skillId = "warrior_slash_blast", displayName = "슬래시 블러스트", job = "warrior", kind = "ACTIVE",
			shape = "ADJACENT4", range = 1, hits = 1, damagePerLv = { 2, 3, 5 },
			desc = "상하좌우 인접한 모든 적을 동시 타격",
			iconRuid = "1dc02c9673284efb94da9c86e7414eeb" })
		addSkill({ skillId = "archer_arrow_blow", displayName = "애로우 블로우", job = "archer", kind = "ACTIVE",
			shape = "LINE", range = 7, hits = 1, damagePerLv = { 2, 3, 5 }, linePierce = true, directional = true,
			desc = "직선으로 화살을 쏘아 일직선상의 적을 관통",
			iconRuid = "5237ce33df53452b8ee7671b48081a56" })
		addSkill({ skillId = "archer_double_shot", displayName = "더블샷", job = "archer", kind = "ACTIVE",
			shape = "LINE", range = 7, hits = 2, damagePerLv = { 2, 3, 4 }, directional = true,
			desc = "화살 2발을 직선으로 발사",
